<h1>Articles</h1>

<% @articles.each do |article| %>
  <article>
    <h2><%= link_to article.title, article %></h2>
    <p><%= truncate(article.body, length: 100) %></p>
    <%= link_to "Read more", article %>
  </article>
<% end %>

<%= link_to "New Article", new_article_path, class: "btn btn-primary" %>